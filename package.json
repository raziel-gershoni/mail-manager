    "next": "^15.5.20",
    "node-html-parser": "^6.1.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "telegramify-markdown": "^1.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
